{
  "manifest_version": 3,
  "key": "",
  "browser_specific_settings": {
    "gecko": {
      "id": "gcr-fetch@ammarasad.com",
      "strict_min_version": "109.0"
    }
  },
  "name": "GCR Fetch",
  "version": "1.0.0",
  "description": "Bulk-download all resources from a Google Classroom course as a ZIP archive.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "identity",
    "scripting",
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://classroom.google.com/*",
    "https://classroom.googleapis.com/*",
    "https://www.googleapis.com/*",
    "https://drive.google.com/*",
    "https://docs.google.com/*",
    "https://gcr-fetch-backend.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": [
        "https://classroom.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "sidebar/sidebar.html",
        "sidebar/sidebar.css",
        "sidebar/sidebar.js",
        "lib/fetcher.js",
        "lib/zipper.js",
        "lib/jszip.min.js",
        "icons/icon128.png"
      ],
      "matches": [
        "https://classroom.google.com/*"
      ]
    }
  ],
  "action": {
    "default_title": "GCR Fetch",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}